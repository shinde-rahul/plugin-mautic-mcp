{
    "name": "shinde-rahul/plugin-mautic-mcp",
    "description": "Mautic MCP server plugin providing controlled tools for AI-assisted development, testing, support, and campaign debugging workflows.",
    "type": "mautic-plugin",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Rahul Shinde",
            "email": "shinde.r.a@gmail.com"
        }
    ],
    "keywords": [
        "mautic",
        "mautic-plugin",
        "mcp",
        "model-context-protocol",
        "ai-tools",
        "developer-tools",
        "campaign-debugging",
        "symfony"
    ],
    "extra": {
        "install-directory-name": "MauticMcpBundle"
    },
    "require": {
        "php": "^8.2",
        "mautic/core-lib": "^7.0",
        "symfony/mcp-bundle": "^0.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "config": {
        "sort-packages": true
    }
}